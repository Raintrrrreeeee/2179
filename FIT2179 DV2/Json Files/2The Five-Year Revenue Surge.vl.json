{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 250,
  "title": {
    "text": "The Five-Year Revenue Surge",
    "subtitle": "Malaysia's Quarterly E-Commerce Income (2020-2024)",
    "fontSize": 18,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "https://raw.githubusercontent.com/Raintrrrreeeee/2179/refs/heads/DV2/FIT2179%20DV2/datasets/2.csv",
    "format": {"type": "csv"}
  },
  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "fill": "white",
      "stroke": "#d35400",
      "strokeWidth": 2,
      "size": 60
    },
    "color": "#d35400",
    "strokeWidth": 3
  },
  "encoding": {
    "x": {
      "field": "Date",
      "type": "temporal",
      "axis": {
        "title": "Timeline (Quarterly)",
        "format": "%Y Q%q",
        "labelAngle": -45,
        "tickCount": 20,
        "grid": false
      }
    },
    "y": {
      "field": "Income_RM_Million",
      "type": "quantitative",
      "scale": {"zero": false},
      "axis": {
        "title": "Income (RM Million)",
        "gridColor": "#ecf0f1"
      }
    },
    "tooltip": [
      {"field": "Year", "type": "ordinal"},
      {"field": "Quarter", "type": "nominal"},
      {"field": "Income_RM_Million", "type": "quantitative", "title": "Income (RM Mil)", "format": ",.0f"}
    ]
  },
  "config": {
    "view": {"stroke": "transparent"}
  }
}
