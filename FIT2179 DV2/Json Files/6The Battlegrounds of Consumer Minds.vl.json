{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 550,
  "height": 280,
  "title": {
    "text": "The Battlegrounds of Consumer Minds",
    "subtitle": [
      "Why Malaysians Choose Each Platform",
      "*Scores based on survey data"
    ],
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#7f8c8d",
    "anchor": "start",
    "offset": 15
  },
  "data": {
    "url": "https://raw.githubusercontent.com/Raintrrrreeeee/2179/refs/heads/DV2/FIT2179%20DV2/datasets/6.csv",
    "format": {"type": "csv"}
  },
  "mark": {"type": "bar", "cornerRadiusTopLeft": 3, "cornerRadiusTopRight": 3},
  "encoding": {
    "x": {
      "field": "Driver",
      "type": "nominal",
      "axis": {
        "title": null,
        "labelAngle": 0,
        "labelFontSize": 12,
        "labelFontWeight": "bold",
        "domainColor": "#bdc3c7",
        "ticks": false
      },
      "sort": [
        "Price & Deals",
        "Trust & Authenticity",
        "Product Variety",
        "Entertainment & Discovery"
      ]
    },
    "xOffset": {
      "field": "Platform",
      "sort": ["Shopee", "TikTok Shop", "Lazada"]
    },
    "y": {
      "field": "Score",
      "type": "quantitative",
      "axis": {
        "title": "Preference Score",
        "titleFontWeight": "normal",
        "titleColor": "#7f8c8d",
        "gridColor": "#ecf0f1",
        "domain": false,
        "ticks": false
      }
    },
    "color": {
      "field": "Platform",
      "type": "nominal",
      "scale": {
        "domain": ["Shopee", "TikTok Shop", "Lazada"],
        "range": ["#ff5e00", "#000000", "#e1007a"]
      },
      "legend": {
        "title": null,
        "orient": "top",
        "direction": "horizontal",
        "labelFontSize": 12
      }
    },
    "tooltip": [
      {"field": "Driver", "type": "nominal", "title": "Battleground"},
      {"field": "Platform", "type": "nominal", "title": "Platform"},
      {"field": "Score", "type": "quantitative", "title": "Score (0-100)"}
    ]
  },
  "config": {"view": {"stroke": "transparent"}}
}