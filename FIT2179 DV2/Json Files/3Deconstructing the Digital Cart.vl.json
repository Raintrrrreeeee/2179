{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 300,
  "height": 230,
  "title": {
    "text": "Deconstructing the Digital Cart",
    "subtitle": [
      "Top Categories by Sales Volume (in Millions)",
      "*sampled as of May 2023"
    ],
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#7f8c8d",
    "anchor": "start",
    "offset": 10
  },
  "data": {
    "url": "https://raw.githubusercontent.com/Raintrrrreeeee/2179/refs/heads/DV2/FIT2179%20DV2/datasets/3.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"calculate": "datum.Sales_Volume / 1000000", "as": "Sales_M"}
  ],
  "encoding": {
    "y": {
      "field": "Main_Category",
      "type": "nominal",
      "sort": [
        "Health & Beauty",
        "Home & Living",
        "Mobile & Accessories",
        "Men Clothes",
        "Baby & Toys",
        "Women Clothes",
        "Others"
      ],
      "axis": {
        "title": null,
        "grid": false,
        "ticks": false,
        "domain": false,
        "labelFontSize": 11,
        "labelFontWeight": "bold",
        "labelColor": "#34495e"
      }
    },
    "x": {
      "field": "Sales_M",
      "type": "quantitative",
      "axis": null
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4,
        "height": {"band": 0.65}
      },
      "encoding": {
        "color": {
          "condition": [
            {
              "test": "datum.Main_Category === 'Health & Beauty'",
              "value": "#d35400"
            },
            {
              "test": "datum.Main_Category === 'Others'",
              "value": "#ecf0f1"
            }
          ],
          "value": "#f39c12"
        }
      }
    },
    {
      "description": "Annotations",
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 5,
        "fontSize": 12,
        "fontWeight": "bold",
        "fill": "#2c3e50"
      },
      "encoding": {
        "text": {"field": "Sales_M", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "description": "Others",
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "dx": -250,
        "dy": 14,
        "fontSize": 10,
        "fontStyle": "italic",
        "fill": "#7f8c8d"
      },
      "encoding": {
        "text": {
          "condition": {
            "test": "datum.Main_Category === 'Others'",
            "value": "The 'Long Tail' (Pets, Groceries, Stationery, Hardware)"
          },
          "value": ""
        }
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"}
  }
}
