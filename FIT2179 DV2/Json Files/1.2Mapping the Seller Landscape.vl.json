{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 200,
  "height": 200,
  "title": {
    "text": "West Malaysia hosts (98.8%) of all active merchants",
    "fontSize": 15,
    "anchor": "middle",
    "color": "#2c3e50",
    "offset": 15
  },
  "background": "transparent",
  "data": {
    "values": [
      {"Region": "West Malaysia (Peninsular)", "Sellers": 7481},
      {"Region": "East Malaysia (Sabah/Sarawak)", "Sellers": 86}
    ]
  },
  "mark": {
    "type": "arc",
    "innerRadius": 55,
    "stroke": "#ffffff",
    "strokeWidth": 2
  },
  "encoding": {
    "theta": {"field": "Sellers", "type": "quantitative"},
    "color": {
      "field": "Region",
      "type": "nominal",
      "scale": {
        "domain": [
          "West Malaysia (Peninsular)",
          "East Malaysia (Sabah/Sarawak)"
        ],
        "range": ["#ff5e00", "#f2f2f2"]
      },
      "legend": null
    },
    "tooltip": [
      {"field": "Region", "type": "nominal"},
      {"field": "Sellers", "type": "quantitative", "format": ","}
    ]
  },
  "layer": [
    {"mark": {"type": "arc"}},
    {
      "mark": {
        "type": "text",
        "fontSize": 26,
        "fontWeight": "bold",
        "fill": "#2c3e50"
      },
      "data": {"values": [{"text": "98.8%"}]},
      "encoding": {"text": {"field": "text"}}
    }
  ],
  "config": {"view": {"stroke": "transparent"}}
}
